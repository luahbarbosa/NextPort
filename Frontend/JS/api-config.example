// ===== TRATAMENTO DE ERROS GLOBAL =====

class APIError extends Error {
    constructor(message, status, response) {
        super(message);
        this.name = 'APIError';
        this.status = status;
        this.response = response;
    }
}

/**
 * Handler centralizado de erros de API
 */
function handleAPIError(error) {
    if (error instanceof APIError) {
        switch (error.status) {
            case 400:
                console.error('Bad Request:', error.message);
                // Mostrar validação ao usuário
                break;
            case 401:
                console.error('Não autorizado');
                // Redirecionar para login
                break;
            case 403:
                console.error('Acesso proibido');
                break;
            case 404:
                console.error('Recurso não encontrado');
                break;
            case 500:
                console.error('Erro do servidor');
                break;
            default:
                console.error('Erro desconhecido:', error.message);
        }
    } else {
        console.error('Network error:', error.message);
    }
}

// ===== INTERCEPTADORES (Opcional) =====

/**
 * Interceptador para modificar requisições antes de enviar
 */
function requestInterceptor(options) {
    // Exemplo: Adicionar custom headers
    return {
        ...options,
        headers: {
            ...options.headers,
            'X-Request-ID': generateUUID()
        }
    };
}

/**
 * Interceptador para processar respostas
 */
function responseInterceptor(response) {
    // Exemplo: Processar metadados
    if (response.meta) {
        console.log('Meta:', response.meta);
    }
    return response;
}

function generateUUID() {
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
        const r = (Math.random() * 16) | 0;
        const v = c === 'x' ? r : (r & 0x3) | 0x8;
        return v.toString(16);
    });
}

