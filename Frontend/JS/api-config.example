 * Este arquivo serve como guia para integração com o backend
 */

// ===== CONFIGURAÇÃO BASE =====
// Altere conforme seu ambiente

const API_CONFIG = {
    // URL base da API
    BASE_URL: process.env.API_BASE_URL || 'https://api.nexport.com/v1',
    
    // Timeout padrão para requisições (em ms)
    TIMEOUT: 10000,
    
    // Headers padrão
    DEFAULT_HEADERS: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
    },

    // Configurações de retry
    RETRY: {
        enabled: true,
        maxAttempts: 3,
        delay: 1000 // ms
    },

    // Ambientes
    ENVIRONMENTS: {
        development: 'http://localhost:3000/api/v1',
        staging: 'https://staging-api.nexport.com/v1',
        production: 'https://api.nexport.com/v1'
    }
};

// ===== ENDPOINTS =====
const ENDPOINTS = {
    // Dashboard
    dashboard: {
        list: '/dashboard',
        metrics: '/dashboard/metrics'
    },

    // Dispositivos
    devices: {
        list: '/devices',
        create: '/devices',
        detail: (id) => `/devices/${id}`,
        update: (id) => `/devices/${id}`,
        delete: (id) => `/devices/${id}`,
        filter: '/devices/filter',
        search: '/devices/search'
    },

    // Residências
    residences: {
        list: '/residences',
        create: '/residences',
        detail: (id) => `/residences/${id}`,
        update: (id) => `/residences/${id}`,
        delete: (id) => `/residences/${id}`
    },

    // Monitoramento
    monitoring: {
        networkMetrics: '/network-metrics',
        deviceStatus: '/device-status',
        alerts: '/alerts'
    },

    // Usuários
    users: {
        profile: '/users/profile',
        update: '/users/profile',
        list: '/users',
        create: '/users'
    },

    // Autenticação
    auth: {
        login: '/auth/login',
        logout: '/auth/logout',
        refresh: '/auth/refresh-token',
        register: '/auth/register'
    }
};

// ===== CLASSE API CLIENT (Exemplo) =====

class APIClient {
    constructor(config = API_CONFIG) {
        this.config = config;
        this.baseURL = config.BASE_URL;
        this.defaultHeaders = config.DEFAULT_HEADERS;
        this.authToken = localStorage.getItem('authToken') || null;
    }

    /**
     * Define o token de autenticação
     */
    setAuthToken(token) {
        this.authToken = token;
        localStorage.setItem('authToken', token);
    }

    /**
     * Obter headers com autenticação
     */
    getHeaders() {
        const headers = { ...this.defaultHeaders };
        
        if (this.authToken) {
            headers['Authorization'] = `Bearer ${this.authToken}`;
        }
        
        return headers;
    }

    /**
     * Requisição GET
     */
    async get(endpoint, options = {}) {
        return this.request(endpoint, {
            method: 'GET',
            ...options
        });
    }

    /**
     * Requisição POST
     */
    async post(endpoint, data, options = {}) {
        return this.request(endpoint, {
            method: 'POST',
            body: JSON.stringify(data),
            ...options
        });
    }

    /**
     * Requisição PUT
     */
    async put(endpoint, data, options = {}) {
        return this.request(endpoint, {
            method: 'PUT',
            body: JSON.stringify(data),
            ...options
        });
    }

    /**
     * Requisição DELETE
     */
    async delete(endpoint, options = {}) {
        return this.request(endpoint, {
            method: 'DELETE',
            ...options
        });
    }

    /**
     * Requisição genérica com retry
     */
    async request(endpoint, options = {}, attempt = 1) {
        try {
            const url = `${this.baseURL}${endpoint}`;
            
            const response = await Promise.race([
                fetch(url, {
                    headers: this.getHeaders(),
                    ...options
                }),
                new Promise((_, reject) =>
                    setTimeout(() => reject(new Error('Request timeout')), this.config.TIMEOUT)
                )
            ]);

            // Tratamento de erro de autenticação
            if (response.status === 401) {
                this.handleUnauthorized();
            }

            if (!response.ok) {
                throw new Error(`HTTP ${response.status}: ${response.statusText}`);
            }

            return await response.json();

        } catch (error) {
            // Retry logic
            if (
                this.config.RETRY.enabled &&
                attempt < this.config.RETRY.maxAttempts &&
                this.isRetryableError(error)
            ) {
                console.warn(`Tentativa ${attempt} falhou. Retentando em ${this.config.RETRY.delay}ms...`);
                await new Promise(resolve => setTimeout(resolve, this.config.RETRY.delay));
                return this.request(endpoint, options, attempt + 1);
            }

            throw error;
        }
    }

    /**
     * Verifica se erro é retentável
     */
    isRetryableError(error) {
        const retryableErrors = [
            'Network request failed',
            'Request timeout',
            'ECONNREFUSED',
            'ENOTFOUND'
        ];
        return retryableErrors.some(msg => error.message.includes(msg));
    }

    /**
     * Tratamento de erro 401 (não autorizado)
     */
    handleUnauthorized() {
        // Limpar token e redirecionar para login
        localStorage.removeItem('authToken');
        this.authToken = null;
        // window.location.href = '/login'; // Uncomment para sua aplicação
        console.error('Sessão expirada. Faça login novamente.');
    }
}

